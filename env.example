# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only — never expose to client

# ── MetaApi ───────────────────────────────────────────────────────────────────
METAAPI_TOKEN=                    # server-side only

# ── OpenAI Whisper ────────────────────────────────────────────────────────────
OPENAI_API_KEY=                   # server-side only

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                # server-side only

# ── Firebase (FCM push notifications ONLY — not Firestore, not Firebase Auth) ─
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=              # server-side only
NEXT_PUBLIC_PRO_PRICE=            # e.g. 49900 (in paise = ₹499/month)
