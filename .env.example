# ── Supabase (required) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.invictusai.tech

# ── MetaAPI — MT5 trade sync (optional) ──────────────────────
# Plug in → MT5 connect form activates in onboarding
METAAPI_TOKEN=your_metaapi_token
NEXT_PUBLIC_METAAPI_ENABLED=false

# ── Claude AI — per-trade feedback + weekly reports (optional) ─
# Plug in → AI feedback and Sunday report generation activates
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── OpenAI Whisper — voice-to-text in journal (optional) ──────
# Plug in → mic button appears in journal note sheet
OPENAI_API_KEY=your_openai_api_key
NEXT_PUBLIC_WHISPER_ENABLED=false

# ── Razorpay — payments (optional) ───────────────────────────
# Plug in → Upgrade button in Settings activates
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_PLAN_ID=your_razorpay_plan_id
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id

# ── Vercel cron secret (set same value in Vercel env + vercel.json) ────
CRON_SECRET=your_cron_secret
